# Copy to .env.secrets and fill before running scripts/scaleway/seed-secrets.sh
# or deploy-container.sh. Keep a backup (1Password, etc.) — this file is the deploy source of truth.
#
# DATABASE_URL: output of provision-infra.sh (private endpoint only, sslmode=require)
# SERVICE_TOKEN_SECRET: openssl rand -hex 32

DATABASE_URL=
SERVICE_TOKEN_SECRET=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HUBSPOT_API_TOKEN=
MONDAY_API_TOKEN=
# Prefer inline JSON on Scaleway (required at deploy). File path works for local seed script:
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=.secrets/tomcat-ai-backend-71e0e34e307f.json
# OAuth Desktop client id only (public). Client secret stays in .secrets/google-oauth-desktop.json locally.
GOOGLE_OAUTH_CLIENT_ID=
# OAuth Web client (MCP OAuth proxy). Required on Scaleway with secret below.
GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_WEB_CLIENT_SECRET=
# Optional local path instead of inline secret (gitignored .secrets/google-oauth-web.json)
GOOGLE_OAUTH_WEB_CLIENT_FILE=.secrets/google-oauth-web.json

# HubSpot Private App → Auth tab → Client secret (UUID format).
# NOT the Access token (pat-na1-...) used as HUBSPOT_API_TOKEN.
HUBSPOT_WEBHOOK_CLIENT_SECRET=

# Public webhook URL used for signature v2/v3 URI matching
HUBSPOT_WEBHOOK_PUBLIC_URL=https://tomcatcore91c5e290-api.functions.fnc.fr-par.scw.cloud/webhooks/hubspot

# HubSpot sync engine tunables (non-secret; can also live in .env)
HUBSPOT_MAX_REQUESTS_PER_10S=90
SYNC_OVERLAP_GRACE_MINUTES=20
SYNC_QUEUE_POLL_INTERVAL_MS=5000
SYNC_QUEUE_BATCH_SIZE=3
SYNC_QUEUE_STALE_JOB_MS=600000
SYNC_QUEUE_RETRY_DELAY_MS=60000
SYNC_RECONCILE_INTERVAL_MS=21600000
SYNC_RECONCILE_LOOKBACK_MS=300000
