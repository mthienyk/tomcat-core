# Copy to .env.secrets and fill before running scripts/scaleway/seed-secrets.sh
# or deploy-container.sh. Keep a backup (1Password, etc.) — this file is the deploy source of truth.
#
# DATABASE_URL: output of provision-infra.sh (private endpoint only, sslmode=require)
# SERVICE_TOKEN_SECRET: openssl rand -hex 32

DATABASE_URL=
SERVICE_TOKEN_SECRET=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HUBSPOT_API_TOKEN=
MONDAY_API_TOKEN=
# Prefer inline JSON on Scaleway (required at deploy). File path works for local seed script:
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=.secrets/tomcat-ai-backend-71e0e34e307f.json
# OAuth Desktop client id only (public). Client secret stays in .secrets/google-oauth-desktop.json locally.
GOOGLE_OAUTH_CLIENT_ID=
