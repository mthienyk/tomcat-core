{
  "name": "tomcat-core",
  "version": "0.1.0",
  "private": true,
  "description": "Tomcat Core: central AI server connecting Tomcat data sources, permissions and natural language access.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.1",
    "fastify": "^5.1.0",
    "google-auth-library": "^9.15.0",
    "jose": "^6.2.3",
    "openai": "^4.73.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.3",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
