# --- Runtime ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# --- Scaleway CLI + deploy (local scripts only, not read by the Node app) ---
# IAM → API Keys at creation time:
#   Access Key ID  → SCALEWAY_ACCESS_KEY_ID  (format SCWXXXXXXXXXXXXXXXXX)
#   Secret Key     → SCALEWAY_SECRET_KEY     (UUID shown once at key creation)
# SCALEWAY_API_KEY is the key resource UUID in the console — not used for auth.
SCALEWAY_ACCESS_KEY_ID=
SCALEWAY_SECRET_KEY=
SCW_DEFAULT_PROJECT_ID=e0af5962-2c29-45f5-8921-b5a8f9976f4d
SCW_DEFAULT_REGION=fr-par
SCW_DEFAULT_ZONE=fr-par-1
# From scripts/scaleway/deploy-container.sh output; also set as GitHub secret SCW_CONTAINER_ID
SCW_CONTAINER_ID=
# Comma separated; required in production (example: https://society.tomcat.eu)
CORS_ALLOWED_ORIGINS=

# --- Deploy secrets (.env.secrets, gitignored) ---
# Copy .env.secrets.example → .env.secrets before seed-secrets.sh / deploy-container.sh.
# Serverless Containers do not read Secret Manager at runtime; deploy injects these as
# encrypted container env vars. Secret Manager is a backup synced by seed-secrets.sh.
#   DATABASE_URL              private Postgres endpoint (sslmode=require)
#   SERVICE_TOKEN_SECRET      openssl rand -hex 32
#   ANTHROPIC_API_KEY
#   OPENAI_API_KEY
#   HUBSPOT_API_TOKEN
#   MONDAY_API_TOKEN
#   GOOGLE_OAUTH_CLIENT_ID          Desktop client id (token verification + CLI)
#   GOOGLE_OAUTH_WEB_CLIENT_ID      Web client id (MCP OAuth proxy)
#   GOOGLE_OAUTH_WEB_CLIENT_SECRET  Web client secret (Scaleway only)

# --- Database (Postgres) ---
# Required in production for: DB role resolver, CoreStore read model, Postgres signal store.
# Dev: leave empty and use SIGNAL_STORE_DRIVER=sqlite. Prod URL lives in .env.secrets (Private Network).
# Example: postgresql://user:pass@172.16.0.2:5432/tomcat_core?sslmode=require
DATABASE_URL=

# --- Auth (humans) ---
# Comma separated list of allowed Google Workspace domains (internal Tomcat users only)
ALLOWED_GOOGLE_DOMAINS=tomcat.eu
# OAuth 2.0 Client ID (Desktop app for CLI/stdio MCP).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_FILE=.secrets/google-oauth-desktop.json
# OAuth Web client (MCP OAuth proxy). Secret in .env.secrets or GOOGLE_OAUTH_WEB_CLIENT_FILE.
GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_WEB_CLIENT_FILE=.secrets/google-oauth-web.json
# Public issuer URL for MCP OAuth discovery (prod Scaleway API base URL).
OAUTH_ISSUER_URL=
# Comma-separated redirect_uri prefixes allowed at POST /oauth/register
OAUTH_ALLOWED_REDIRECT_URI_PREFIXES=cursor://,https://www.cursor.com/,http://localhost:
# Written by npm run auth:google; used by npm run mcp:stdio when GOOGLE_OAUTH_CLIENT_ID is set.
GOOGLE_ID_TOKEN_FILE=.secrets/google-id-token
# Full session (id token + refresh token). Preferred for MCP auto-refresh.
GOOGLE_OAUTH_SESSION_FILE=.secrets/google-oauth-session.json

# --- Auth (machine to machine) ---
# Used to sign and verify service JWTs (HS256). Generate: openssl rand -hex 32
SERVICE_TOKEN_SECRET=replace-me-with-long-random-string
SERVICE_TOKEN_ISSUER=tomcat-core
SERVICE_TOKEN_AUDIENCE=tomcat-core
# Comma separated client ids that may call the Core. Format: clientId:scope1|scope2
SERVICE_CLIENTS=society:society.read|society.write,team-mcp:ai.query|briefs.write
# For Society endpoints called by service JWTs, external investor delegation must include act_as.investorId.

# --- Dev only ---
# When true, accepts a header X-Mock-Identity to bypass real auth (dev only).
ALLOW_MOCK_AUTH=true

# --- Connectors (leave empty to return 503 on dependent endpoints) ---
HUBSPOT_API_TOKEN=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=
# Optional: restrict Drive search to one Shared Drive (add service account as Reader on that drive)
GOOGLE_DRIVE_SHARED_DRIVE_ID=
MONDAY_API_TOKEN=

# --- Signal Hub ---
# Serper.dev API key (https://serper.dev) — public LinkedIn search via Google SERP.
# No LinkedIn account needed. ~1€ per 1000 queries.
SERPER_API_KEY=
# Unipile DSN and API key (https://developer.unipile.com) — private LinkedIn feed (read-only).
# DSN format: https://apiX.unipile.com:PORT (from your Unipile dashboard)
UNIPILE_DSN=
UNIPILE_API_KEY=
# HMAC-SHA256 secret for verifying Unipile webhook payloads. Required in production. Set in Unipile dashboard.
UNIPILE_WEBHOOK_SECRET=
# Signal store backend: sqlite (default) or postgres (requires DATABASE_URL).
SIGNAL_STORE_DRIVER=sqlite
# SQLite file path when driver is sqlite (default: .data/signal-hub.db). Use an absolute path in production.
SIGNAL_STORE_PATH=.data/signal-hub.db
# Daily call quota per Unipile account (default 60, max 100). Under LinkedIn threshold.
UNIPILE_DAILY_QUOTA=60
# Skip scheduler tick when a sync run is still running within this window (minutes).
SYNC_OVERLAP_GRACE_MINUTES=20

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-6
