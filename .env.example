# --- Runtime ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
# Comma separated; required in production (example: https://society.tomcat.eu)
CORS_ALLOWED_ORIGINS=

# --- Auth (humans) ---
# Comma separated list of allowed Google Workspace domains
ALLOWED_GOOGLE_DOMAINS=tomcat.eu
GOOGLE_OAUTH_CLIENT_ID=

# --- Auth (machine to machine) ---
# Used to sign and verify service JWTs (HS256). Generate a long random string.
SERVICE_TOKEN_SECRET=replace-me-with-long-random-string
SERVICE_TOKEN_ISSUER=tomcat-core
SERVICE_TOKEN_AUDIENCE=tomcat-core
# Comma separated client ids that may call the Core. Format: clientId:scope1|scope2
SERVICE_CLIENTS=society:society.read|society.write,team-mcp:ai.query|briefs.write
# For Society endpoints called by service JWTs, external investor delegation must include act_as.investorId.

# --- Dev only ---
# When true, accepts a header X-Mock-Identity to bypass real auth (dev only).
ALLOW_MOCK_AUTH=true

# --- Connectors (leave empty to return 503 on dependent endpoints) ---
HUBSPOT_API_TOKEN=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=
# Optional: restrict Drive search to one Shared Drive (add service account as Reader on that drive)
GOOGLE_DRIVE_SHARED_DRIVE_ID=
MONDAY_API_TOKEN=

# --- Signal Hub ---
# Serper.dev API key (https://serper.dev) — public LinkedIn search via Google SERP.
# No LinkedIn account needed. ~1€ per 1000 queries.
SERPER_API_KEY=
# Unipile DSN and API key (https://developer.unipile.com) — private LinkedIn feed (read-only).
# DSN format: https://apiX.unipile.com:PORT (from your Unipile dashboard)
UNIPILE_DSN=
UNIPILE_API_KEY=
# HMAC-SHA256 secret for verifying Unipile webhook payloads. Set in Unipile dashboard.
UNIPILE_WEBHOOK_SECRET=
# SQLite store path (default: .data/signal-hub.db). Use an absolute path in production.
SIGNAL_STORE_PATH=.data/signal-hub.db
# Daily call quota per Unipile account (default 60, max 100). Under LinkedIn threshold.
UNIPILE_DAILY_QUOTA=60

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-6
